# Install as an external root-readable environment file. Never commit real values.
CLAW_BRIDGE_TOKEN=replace-with-at-least-32-random-characters
CLAW_BRIDGE_HOST=127.0.0.1
CLAW_BRIDGE_PORT=19090
CLAW_BRIDGE_STATE_FILE=/home/clawrun/analise_storage/state/telegram-claw-projects.json
CLAW_PROJECTS_ROOT=/home/clawrun/analise_storage/telegram-projects
CLAW_BINARY=/home/clawrun/analise_storage/claw-code-parity/rust/target/release/claw
CLAW_MODEL=gemma4
# Preferred over CLAW_SYSTEM_PROMPT. The patched OpenAI-compatible provider
# reads this file for every model call, so prompt edits require only replacing
# the file; restarting the bridge is needed only when this path changes.
CLAW_SYSTEM_PROMPT_FILE=/home/clawrun/analise_storage/claw-code-parity/integrations/telegram/prompts/gemma4-abliterated-system-prompt.txt
CLAW_ALLOWED_TOOLS=read,write,edit,glob,grep,bash,WebFetch,WebSearch,Agent,Sleep
CLAW_PERMISSION_MODE=workspace-write
CLAW_TURN_TIMEOUT=900
CLAW_MAX_CONCURRENT=2
CLAW_MAX_ATTACHMENT_BYTES=20971520
# Keep this below the effective per-slot Gemma context. Use 22000 for a 32K
# slot. The measured two-slot Gemma profile has 163840 tokens per slot and uses
# 110000 (67.1%), leaving 53840 tokens for tools, images and output.
CLAW_AUTO_COMPACT_INPUT_TOKENS=110000
# Per model call. Telegram splits the returned text into 3900-character
# messages, so a multi-message answer is preserved without raising this to the
# full physical context window.
CLAW_GEMMA_MAX_OUTPUT_TOKENS=4096
CLAW_OCR_TIMEOUT=180
CLAW_OCR_LANGUAGES=rus+eng
GOOGLE_BASE_URL=http://127.0.0.1:18080/v1
GOOGLE_API_KEY=local-gemma
