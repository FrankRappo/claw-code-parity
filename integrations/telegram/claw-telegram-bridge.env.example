# Install as an external root-readable environment file. Never commit real values.
CLAW_BRIDGE_TOKEN=replace-with-at-least-32-random-characters
CLAW_BRIDGE_HOST=127.0.0.1
CLAW_BRIDGE_PORT=19090
CLAW_BRIDGE_STATE_FILE=/home/clawrun/analise_storage/state/telegram-claw-projects.json
CLAW_PROJECTS_ROOT=/home/clawrun/analise_storage/telegram-projects
CLAW_BINARY=/home/clawrun/analise_storage/claw-code-parity/rust/target/release/claw
CLAW_MODEL=gemma4
CLAW_ALLOWED_TOOLS=read,write,edit,glob,grep,bash
CLAW_PERMISSION_MODE=workspace-write
CLAW_TURN_TIMEOUT=900
CLAW_MAX_CONCURRENT=2
CLAW_MAX_ATTACHMENT_BYTES=20971520
# Keep this below the effective per-slot Gemma context. 22000 is safe for 32K.
CLAW_AUTO_COMPACT_INPUT_TOKENS=22000
CLAW_GEMMA_MAX_OUTPUT_TOKENS=4096
CLAW_OCR_TIMEOUT=180
CLAW_OCR_LANGUAGES=rus+eng
GOOGLE_BASE_URL=http://127.0.0.1:18080/v1
GOOGLE_API_KEY=local-gemma
