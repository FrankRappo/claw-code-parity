TELEGRAM_BOT_TOKEN=replace-me
BOT_ALLOWED_USER_IDS=123456789
LLM_BASE_URL=http://127.0.0.1:18080
SYSTEM_PROMPT_FILE=/opt/tg-gemma-bot/gemma4-abliterated-system-prompt.txt
CLAW_BRIDGE_URL=http://127.0.0.1:19090
CLAW_BRIDGE_TOKEN=use-the-same-random-token-as-the-bridge
CHAT_MODE_STATE_FILE=/var/lib/tg-gemma-bot/chat-modes.json
MAX_TOKENS=4096
MAX_RESPONSE_TOKENS=8192
MAX_IMAGE_BYTES=10485760
MAX_PDF_BYTES=20971520
# 0 keeps the HTTP request open until Claw finishes or `/stop` interrupts it.
CLAW_REQUEST_TIMEOUT=0
# Same ceiling as Claw; short Vision preprocessing still ends at EOS.
CLAW_VISION_MAX_TOKENS=32000
# 0 removes the automatic Vision preprocessing cutoff.
CLAW_VISION_REQUEST_TIMEOUT=0
# Read-only natural-language progress observer; falls back immediately when
# both Gemma slots are busy.
CLAW_OBSERVER_MAX_TOKENS=512
CLAW_OBSERVER_REQUEST_TIMEOUT=90
BOT_MAX_CONCURRENT_REQUESTS=4
